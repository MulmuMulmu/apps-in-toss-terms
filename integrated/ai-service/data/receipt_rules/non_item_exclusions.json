{
  "version": 1,
  "updated_at": "2026-04-16",
  "description": "Receipt line patterns that are not item candidates.",
  "categories": [
    {
      "name": "header",
      "contains": [
        "상품명",
        "단가",
        "수량",
        "금액",
        "주문번호",
        "판매",
        "영수증"
      ],
      "regex": [
        "^(?:\\d{2,}|[A-Z]{2,})\\s*(?:매장|지점|점)$",
        "^(?:\\[판매\\]|\\[주문\\]).*$"
      ]
    },
    {
      "name": "summary",
      "contains": [
        "합계",
        "총계",
        "구매금액",
        "결제금액",
        "결제대상액",
        "최종결제",
