        "과세물품",
        "공급가액",
        "부가세",
        "세액"
      ],
      "regex": [
        "^\\s*(?:합계|총계|구매금액|결제금액|결제대상액|최종결제)\\s*[: ]?.*$",
        "^\\s*(?:과세물품가액|과세물품|공급가액|부가세|세액)\\s*[: ]?.*$"
      ]
    },
    {
