      "regex": [
        "^\\s*(?:카드|현금|신용카드|승인번호|거래승인).*$",
        "^\\s*\\*?\\d{8,}.*(?:승인|승인번호|전표).*$"
      ]
    },
    {
      "name": "discount",
      "contains": [
        "할인",
        "쿠폰",
        "행사",
        "포인트",
        "적립",
        "에누리",
        "S-POINT"
      ],
      "regex": [
        "^\\s*[-+]?\\d{1,3}(?:,\\d{3})+\\s*(?:할인|쿠폰|행사).*$",
        "^\\s*.*(?:에누리|S-POINT).*$"
      ]
    },
    {
      "name": "packaging",
      "contains": [
        "봉투",
        "보증금",
        "재사용",
        "포장",
        "용기",
        "종량"
      ],
      "regex": [
        "^\\s*.*(?:봉투|보증금|재사용봉투).*$",
        "^\\s*.*(?:포장|용기).*$",
        "^\\s*\\*?종량\\d+[A-Z]?$"
      ]
    },
    {
      "name": "metadata",
      "contains": [
        "사업자",
        "대표",
        "전화",
        "주소",
        "TEL",
        "www",
        "주문",
        "안내",
        "감사",
        "지점",
        "회원만료일",
        "보험",
        "본인부담",
        "약제비",
        "비보험"
      ],
      "regex": [
        "^\\s*.*(?:사업자등록번호|대표자|전화번호|주소|TEL|www).*$",
        "^\\s*.*(?:감사합니다|안내문|교환|환불).*$",
        "^\\s*.*(?:회원만료일).*$",
        "^\\s*\\)?\\s*[A-Z0-9-]{6,}.*지점$",
        "^\\s*\\)?\\s*YLDP[A-Z0-9]+.*$",
        "^\\s*.*(?:보험자부담|비급여|비보험조제|약제비).*$"
      ]
    },
    {
      "name": "non_food",
      "contains": [
        "수세미",
        "샤오미",
        "구글홈미니",
        "칫솔",
        "칫속",
        "부탄가스",
        "건전지",
        "배터리"
      ],
      "regex": [
        "^\\s*.*(?:수세미|샤오미|구글홈미니|칫솔|칫속|부탄가스|건전지|배터리).*$"
      ]
    }
  ]
}
