FROM node:22-alpine AS build

WORKDIR /app

ENV EXPO_NO_TELEMETRY=1
ARG EXPO_PUBLIC_API_BASE_URL
ARG EXPO_PUBLIC_KAKAO_MAP_KEY
ARG EXPO_PUBLIC_DEV_BYPASS_APPINTOSS_LOGIN
ARG EXPO_PUBLIC_ENABLE_AD_BANNER
ARG EXPO_PUBLIC_APPS_IN_TOSS_BANNER_AD_GROUP_ID
ENV EXPO_PUBLIC_API_BASE_URL=$EXPO_PUBLIC_API_BASE_URL
ENV EXPO_PUBLIC_KAKAO_MAP_KEY=$EXPO_PUBLIC_KAKAO_MAP_KEY
ENV EXPO_PUBLIC_DEV_BYPASS_APPINTOSS_LOGIN=$EXPO_PUBLIC_DEV_BYPASS_APPINTOSS_LOGIN
ENV EXPO_PUBLIC_ENABLE_AD_BANNER=$EXPO_PUBLIC_ENABLE_AD_BANNER
ENV EXPO_PUBLIC_APPS_IN_TOSS_BANNER_AD_GROUP_ID=$EXPO_PUBLIC_APPS_IN_TOSS_BANNER_AD_GROUP_ID

COPY package*.json ./
RUN npm ci

COPY . .
RUN npx expo export --platform web --output-dir dist

FROM nginx:1.27-alpine

COPY nginx.conf.template /etc/nginx/templates/default.conf.template
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 8080

CMD ["/bin/sh", "-c", "envsubst '$PORT' < /etc/nginx/templates/default.conf.template > /etc/nginx/conf.d/default.conf && nginx -g 'daemon off;'"]
